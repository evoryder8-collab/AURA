# Edge Functions only. Copy to an ignored local file; never expose these as VITE_ values.
# SUPABASE_URL, SUPABASE_ANON_KEY, and SUPABASE_SERVICE_ROLE_KEY are injected by
# Supabase in hosted deployments and by the local CLI.

APP_ORIGIN=http://localhost:5173
APP_BASE_URL=http://localhost:5173/

# Generate independent high-entropy values. Do not reuse a password or commit a value.
HANDOFF_TOKEN_PEPPER=replace-with-at-least-32-random-characters
RATE_LIMIT_PEPPER=replace-with-an-independent-random-value

# Optional provider-neutral narration adapter. Without all three values, the
# deterministic fallback remains fully operational.
AI_PROVIDER=disabled
AI_PROVIDER_URL=
AI_API_KEY=
